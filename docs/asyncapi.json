            "description": "Server timestamp (UTC)",
            "format": "date-time",
            "title": "TS",
            "type": "string"
          },
          "type": {
            "description": "Error message type (error)",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "type",
          "data"
        ],
        "title": "realtime.ErrorEnvelope",
        "type": "object"
      },
      "wsdocs.PushGeneralChatReplyData": {
        "additionalProperties": false,
        "properties": {
          "event_id": {
            "description": "Event UUID",
            "type": "string"
          },
          "message_id": {
            "description": "Reply message UUID (dedupe key)",
            "type": "string"
          },
          "reply_to_message_id": {
            "description": "Parent message UUID the recipient authored",
            "type": "string"
          },
          "sender_name": {
            "description": "Replier display name (same as notification title)",
            "type": "string"
          },
          "sender_user_id": {
            "description": "Replier user UUID",
            "type": "string"
          },
          "type": {
            "description": "Always general_chat_reply",
            "type": "string"
          }
        },
        "required": [
          "type",
          "event_id",
          "message_id",
          "reply_to_message_id",
          "sender_name",
          "sender_user_id"
        ],
        "title": "wsdocs.PushGeneralChatReplyData",
        "type": "object"
      },
      "wsdocs.PushEventAnnouncementData": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "description": "Deep-link action: info",
            "type": "string"
          },
          "announcement_id": {
            "description": "Announcement UUID (dedupe key)",
            "type": "string"
          },
          "event_id": {
            "description": "Event UUID",
            "type": "string"
          },
          "session_id": {
            "description": "Present when action is open_session",
            "type": "string"
          },
          "type": {
            "description": "Always event_announcement",
            "type": "string"
          },
          "url": {
            "description": "HTTPS URL when action is open_url",
            "type": "string"
          }
        },
        "required": [
          "type",
          "event_id",
          "announcement_id",
          "action"
        ],
        "title": "wsdocs.PushEventAnnouncementData",
        "type": "object"
      }
    },
    "messages": {
      "agenda_invalidate": {
        "name": "agenda.invalidate",
        "description": "Invalidate attendee agenda; client refetches REST schedule-simple.",
        "payload": {
          "$ref": "#/components/schemas/realtime.AgendaInvalidateEnvelope"
        }
      },
      "session_checked_in": {
        "name": "session.checked_in",
        "description": "Attendee session checked-in; topic attendee.agenda.{event_id}.",
        "payload": {
          "$ref": "#/components/schemas/realtime.SessionCheckedInEnvelope"
        }
      },
      "session_status_changed": {
        "name": "session.status_changed",
        "description": "Session lifecycle status changed; topic organizer.agenda.{event_id}. Event managers only.",
        "payload": {
          "$ref": "#/components/schemas/realtime.OrganizerSessionStatusEnvelope"
        }
      },
      "chat_message": {
        "name": "chat.message",
        "description": "Chat message delivered on attendee.chat.{event_id}.general, attendee.chat.{event_id}.dm.inbox (DM inbox; server routes to authenticated user), or organizer.chat.{event_id} (event managers only).",
        "payload": {
          "$ref": "#/components/schemas/realtime.ChatMessageEnvelope"
        }
      },
      "chat_message_deleted": {
        "name": "chat.message.deleted",
        "description": "Chat message deleted by sender or organizer (general only) on attendee.chat.{event_id}.general, by sender on attendee.chat.{event_id}.dm.inbox, or by sender on organizer.chat.{event_id}.",
        "payload": {
          "$ref": "#/components/schemas/realtime.ChatMessageDeletedEnvelope"
        }
      },
      "chat_reaction_added": {
        "name": "chat.reaction.added",
        "description": "Emoji reaction added or changed on attendee.chat.{event_id}.general, attendee.chat.{event_id}.dm.inbox, or organizer.chat.{event_id}.",
        "payload": {
          "$ref": "#/components/schemas/realtime.ChatReactionEnvelope"
        }
      },
      "chat_reaction_removed": {
        "name": "chat.reaction.removed",
        "description": "Emoji reaction removed on attendee.chat.{event_id}.general, attendee.chat.{event_id}.dm.inbox, or organizer.chat.{event_id}.",
        "payload": {
          "$ref": "#/components/schemas/realtime.ChatReactionEnvelope"
        }
      },
      "subscribe": {
        "name": "subscribe",
        "description": "Client control: subscribe to a topic.",
        "payload": {
          "$ref": "#/components/schemas/realtime.SubscribeEnvelope"
        }
      },
      "unsubscribe": {
        "name": "unsubscribe",
        "description": "Client control: unsubscribe from a topic.",
        "payload": {
          "$ref": "#/components/schemas/realtime.UnsubscribeEnvelope"
        }
      },
      "ping": {
        "name": "ping",
        "description": "Client control: ping (server replies pong).",
        "payload": {
          "$ref": "#/components/schemas/realtime.PingEnvelope"
        }
      },
      "pong": {
        "name": "pong",
        "description": "Server control: pong response.",
        "payload": {
          "$ref": "#/components/schemas/realtime.PongEnvelope"
        }
      },
      "error": {
        "name": "error",
        "description": "Server error frame.",
        "payload": {
          "$ref": "#/components/schemas/realtime.ErrorEnvelope"
        }
      },
      "push_general_chat_reply": {
        "name": "push.general_chat_reply",
        "description": "FCM push to the parent message author (attendee app tokens only). Triggered by POST /attendee/events/{eventID}/chat/general/messages with reply_to_message_id. Not delivered on WebSocket.",
        "payload": {
          "$ref": "#/components/schemas/wsdocs.PushGeneralChatReplyData"
        }
      },
      "push_event_announcement": {
        "name": "push.event_announcement",
        "description": "FCM push to checked-in attendees (attendee app tokens only). Triggered by POST /events/{eventID}/announcements. History: GET /events/{eventID}/announcements. Not delivered on WebSocket.",
        "payload": {
          "$ref": "#/components/schemas/wsdocs.PushEventAnnouncementData"
        }
      }
    },
    "x-pushNotifications": {
